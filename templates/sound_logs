<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>入口音量ログ一覧</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="p-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">入口音量ログ一覧</h3>
    <div>
      <a href="/sound" class="btn btn-outline-success btn-sm me-2">現在の状態</a>
      <a href="/" class="btn btn-outline-secondary btn-sm">カレンダーへ戻る</a>
    </div>
  </div>

  <div class="mb-2">
    <label class="form-label me-2">表示件数</label>
    <select id="limitSelect" class="form-select form-select-sm"
            style="width:auto; display:inline-block;">
      <option value="100">100件</option>
      <option value="500">500件</option>
      <option value="1000" selected>1000件</option>
      <option value="2000">2000件</option>
    </select>
  </div>

  <p class="text-muted small">
    新しい順に最大 <span id="limitLabel">1000</span> 件を表示します。
  </p>

  <table class="table table-sm table-striped">
    <thead>
      <tr>
        <th style="width: 40%;">時刻</th>
        <th style="width: 30%;">状態</th>
        <th style="width: 30%;">レベル</th>
      </tr>
    </thead>
    <tbody id="logBody">
      <tr><td colspan="3">読み込み中...</td></tr>
    </tbody>
  </table>

  <script>
    async function loadLogs(limit) {
      document.getElementById("limitLabel").textContent = limit;
      const tbody = document.getElementById("logBody");
      tbody.innerHTML = '<tr><td colspan="3">読み込み中...</td></tr>';

      try {
        const res = await fetch(`/api/sound_logs_recent?limit=${limit}`);
        if (!res.ok) {
          tbody.innerHTML = '<tr><td colspan="3">読み込みに失敗しました</td></tr>';
          return;
        }
        const rows = await res.json();
        if (!rows.length) {
          tbody.innerHTML = '<tr><td colspan="3">データがありません</td></tr>';
          return;
        }

        tbody.innerHTML = "";
        for (const r of rows) {
          const tr = document.createElement("tr");

          const tdTs = document.createElement("td");
          tdTs.textContent = r.ts;

          const tdStatus = document.createElement("td");
          tdStatus.textContent = r.status;

          const tdLevel = document.createElement("td");
          tdLevel.textContent = r.level;

          tr.appendChild(tdTs);
          tr.appendChild(tdStatus);
          tr.appendChild(tdLevel);
          tbody.appendChild(tr);
        }
      } catch (e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="3">エラーが発生しました</td></tr>';
      }
    }

    const limitSelect = document.getElementById("limitSelect");
    limitSelect.addEventListener("change", () => {
      const limit = parseInt(limitSelect.value, 10) || 1000;
      loadLogs(limit);
    });

    // 初期表示：直近1000件
    loadLogs(1000);
  </script>
</body>
</html>
